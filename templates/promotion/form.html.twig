{% extends 'base_admin.html.twig' %}

{% block title %}
    {{ mode == 'creation' ? 'Nouvelle promotion' : 'Modifier la promotion' }} | Farmtech
{% endblock %}

{% block body %}
    <section class="sheet-layout">
        <aside class="sheet-backdrop">
            <p class="hero__eyebrow">Gestion des promotions</p>
            <h2>{{ mode == 'creation' ? 'Créer une promotion' : 'Mettre à jour la promotion' }}</h2>
            <p>
                Définissez la réduction, sa période de validité, la quantité minimale déclenchante
                et les produits qui en bénéficient.
            </p>
            <div style="margin-top: 20px;">
                <a class="button-ghost" href="{{ path('app_promotion_index') }}">Retour aux promotions</a>
            </div>
        </aside>

        <article class="sheet">
            <div class="sheet__header">
                <div>
                    <h1 class="sheet__title">{{ mode == 'creation' ? 'Nouvelle promotion' : promotion.nom }}</h1>
                    <p class="sheet__copy">
                        Les valeurs saisies s'appliquent immédiatement aux produits sélectionnés,
                        sous réserve des dates et de la quantité minimale.
                    </p>
                </div>
                <a class="button-ghost" href="{{ path('app_promotion_index') }}">Annuler</a>
            </div>

            {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}
                {% if not form.vars.valid %}
                    <div class="form-errors">
                        {{ form_errors(form) }}
                    </div>
                {% endif %}

                <div class="form-grid form-grid--two">
                    <div class="field-group">
                        {{ form_label(form.nom) }}
                        {{ form_widget(form.nom) }}
                        {% for error in form.nom.vars.errors %}
                            <p class="field-error">{{ error.message }}</p>
                        {% endfor %}
                    </div>

                    <div class="field-group">
                        {{ form_label(form.typeReduction) }}
                        {{ form_widget(form.typeReduction) }}
                        {% for error in form.typeReduction.vars.errors %}
                            <p class="field-error">{{ error.message }}</p>
                        {% endfor %}
                        <p class="help-text">Pourcentage = 0-100, Montant fixe = en €</p>
                    </div>

                    <div class="field-group">
                        {{ form_label(form.valeurReduction) }}
                        {{ form_widget(form.valeurReduction) }}
                        {% for error in form.valeurReduction.vars.errors %}
                            <p class="field-error">{{ error.message }}</p>
                        {% endfor %}
                    </div>

                    <div class="field-group">
                        {{ form_label(form.quantiteMin) }}
                        {{ form_widget(form.quantiteMin) }}
                        {% for error in form.quantiteMin.vars.errors %}
                            <p class="field-error">{{ error.message }}</p>
                        {% endfor %}
                        <p class="help-text">Quantité minimale d'achat pour déclencher cette promo</p>
                    </div>

                    <div class="field-group">
                        {{ form_label(form.dateDebut) }}
                        {{ form_widget(form.dateDebut) }}
                        {% for error in form.dateDebut.vars.errors %}
                            <p class="field-error">{{ error.message }}</p>
                        {% endfor %}
                    </div>

                    <div class="field-group">
                        {{ form_label(form.dateFin) }}
                        {{ form_widget(form.dateFin) }}
                        {% for error in form.dateFin.vars.errors %}
                            <p class="field-error">{{ error.message }}</p>
                        {% endfor %}
                    </div>
                </div>

                <div class="field-group">
                    {{ form_label(form.description) }}
                    {{ form_widget(form.description) }}
                    {% for error in form.description.vars.errors %}
                        <p class="field-error">{{ error.message }}</p>
                    {% endfor %}
                </div>

                <div class="field-group">
                    {{ form_label(form.produits) }}
                    {{ form_widget(form.produits) }}
                    {% for error in form.produits.vars.errors %}
                        <p class="field-error">{{ error.message }}</p>
                    {% endfor %}
                    <p class="help-text">Maintenez Ctrl (ou Cmd sur macOS) pour sélectionner plusieurs produits.</p>
                </div>

                <div class="form-grid form-grid--two">
                    <div class="field-group field-group--checkbox">
                        {{ form_widget(form.cumulable) }}
                        {{ form_label(form.cumulable) }}
                        {% for error in form.cumulable.vars.errors %}
                            <p class="field-error">{{ error.message }}</p>
                        {% endfor %}
                        <p class="help-text">Si décochée, cette promo ne se cumule pas avec d'autres</p>
                    </div>

                    <div class="field-group field-group--checkbox">
                        {{ form_widget(form.actif) }}
                        {{ form_label(form.actif) }}
                        {% for error in form.actif.vars.errors %}
                            <p class="field-error">{{ error.message }}</p>
                        {% endfor %}
                        <p class="help-text">Décochez pour désactiver sans supprimer la promotion.</p>
                    </div>
                </div>

                <div class="form-actions">
                    <p class="help-text">
                        {{ mode == 'creation' ? 'La promotion sera immédiatement évaluée selon sa période et ses produits ciblés.' : 'Les modifications prennent effet immédiatement sur les produits liés.' }}
                    </p>

                    <div class="detail-panel__actions">
                        <a class="button-ghost" href="{{ path('app_promotion_index') }}">Annuler</a>
                        <button class="button" type="submit">{{ mode == 'creation' ? 'Créer' : 'Modifier' }}</button>
                    </div>
                </div>
            {{ form_end(form) }}
        </article>
    </section>
{% endblock %}

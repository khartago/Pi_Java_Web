{% extends 'front/layout.html.twig' %}
{% import '_macros/probleme_labels.html.twig' as pl %}

{% block title %}{{ probleme.type }} — FARMTECH{% endblock %}

{% block front_content %}
<section class="farmer-detail-head">
    <span class="farmer-detail-head__eyebrow">Dossier</span>
    <h1>{{ probleme.type }}</h1>
    <div class="detail-meta">
        <span class="badge badge-warn">{{ probleme.gravite }}</span>
        <span class="badge badge-info">{{ pl.etat_label(probleme.etat) }}</span>
        <span style="color:var(--color-muted);font-size:0.92rem;">{{ probleme.dateDetection|date('d/m/Y à H:i') }}</span>
    </div>
</section>

<div class="detail-grid">
    <div class="card">
        <h3 class="font-display" style="margin-top:0;">Description</h3>
        <p style="margin:0;line-height:1.65;">{{ probleme.description|nl2br }}</p>
        {% if plantationLabel %}
            <p style="margin-top:1rem;margin-bottom:0;"><strong>Plantation</strong> — {{ plantationLabel }}</p>
        {% endif %}
        {% if produitLabel %}
            <p style="margin-top:0.5rem;margin-bottom:0;"><strong>Produit</strong> — {{ produitLabel }}</p>
        {% endif %}
        {% if meteoData is iterable %}
            <div class="card" style="margin-top:1rem;padding:0.85rem;background:rgba(26,77,46,0.06);border-radius:8px;">
                <p style="margin:0 0 0.35rem;font-weight:600;">Météo au signalement</p>
                {% if meteoData.temp is defined %}
                    <p style="margin:0;font-size:0.92rem;">Température : {{ meteoData.temp }} °C</p>
                {% endif %}
                {% if meteoData.description is defined %}
                    <p style="margin:0.35rem 0 0;font-size:0.92rem;">Conditions : {{ meteoData.description }}</p>
                {% endif %}
                {% if meteoData.humidity is defined and meteoData.humidity > 0 %}
                    <p style="margin:0.35rem 0 0;font-size:0.92rem;">Humidité : {{ meteoData.humidity }}%</p>
                {% endif %}
                {% if meteoData.lat is defined and meteoData.lon is defined %}
                    <p style="margin:0.35rem 0 0;font-size:0.92rem;">Coordonnées : {{ meteoData.lat }}, {{ meteoData.lon }}</p>
                {% endif %}
                {% if meteoData.timestamp is defined %}
                    <p style="margin:0.35rem 0 0;font-size:0.85rem;color:var(--color-muted);">Relevé : {{ meteoData.timestamp|date('d/m/Y H:i') }}</p>
                {% endif %}
            </div>
        {% else %}
            <p style="margin-top:1rem;margin-bottom:0;font-size:0.9rem;color:var(--color-muted);">Météo indisponible pour ce signalement.</p>
        {% endif %}
        {% if probleme.photos %}
            <p style="margin-top:1rem;margin-bottom:0;"><strong>Photos</strong></p>
            {% include '_includes/probleme_photo_gallery.html.twig' with { photos: probleme.photos } only %}
        {% endif %}
    </div>

    {% if diagnostic %}
    <div class="card card--highlight">
        <h3 class="font-display" style="margin-top:0;">Diagnostic approuvé</h3>
        <p><strong>Cause</strong></p>
        <p style="margin-top:0.35rem;">{{ diagnostic.cause|nl2br }}</p>
        <p style="margin-top:1rem;"><strong>Solution proposée</strong></p>
        <p style="margin-top:0.35rem;">{{ diagnostic.solutionProposee|nl2br }}</p>
        <p style="margin-top:1rem;"><strong>Résultat</strong> — {{ diagnostic.resultat }}</p>
        {% if diagnostic.medicament %}
            <p style="margin-top:1rem;"><strong>Traitement</strong></p>
            <p style="margin-top:0.35rem;">{{ diagnostic.medicament|nl2br }}</p>
        {% endif %}
        <p style="color:var(--color-muted);font-size:0.88rem;margin-top:1.25rem;margin-bottom:0;">Révision {{ diagnostic.numRevision }} · {{ diagnostic.dateDiagnostique|date('d/m/Y H:i') }}</p>
        {% if allRevisions is defined and allRevisions|length > 0 %}
            <div style="margin-top:1rem;border-top:1px solid rgba(255,255,255,0.18);padding-top:0.85rem;">
                <p style="margin:0 0 0.35rem;font-weight:600;">Historique des réponses</p>
                <ul style="margin:0;padding-left:1.1rem;line-height:1.5;">
                    {% for rev in allRevisions %}
                        <li style="margin-bottom:0.5rem;">
                            <strong>Réponse {{ loop.index }} — Révision {{ rev.numRevision }}</strong>
                            <span style="color:var(--color-muted);font-size:0.88rem;"> · {{ rev.dateDiagnostique|date('d/m/Y H:i') }}</span>
                            {% if rev.approuve %}
                                <span class="badge badge-info">approuvée</span>
                            {% else %}
                                <span class="badge badge-warn">en attente</span>
                            {% endif %}
                            <div style="margin-top:0.25rem;font-size:0.88rem;color:var(--color-muted);">
                                <strong>Cause :</strong> {{ rev.cause|slice(0, 180) }}{% if rev.cause|length > 180 %}…{% endif %}
                            </div>
                            <div style="margin-top:0.15rem;font-size:0.88rem;color:var(--color-muted);">
                                <strong>Solution :</strong> {{ rev.solutionProposee|slice(0, 180) }}{% if rev.solutionProposee|length > 180 %}…{% endif %}
                            </div>
                        </li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}
    </div>

    {% if feedbackForm %}
        <div class="card">
            <h3 class="font-display" style="margin-top:0;">Votre avis</h3>
            {{ form_start(feedbackForm) }}
                {{ form_row(feedbackForm.feedbackFermier) }}
                {{ form_row(feedbackForm.feedbackCommentaire) }}
                <div class="form-actions" style="border:none;padding-top:0;margin-top:0;">
                    <button class="btn btn-primary" type="submit">Envoyer le feedback</button>
                </div>
            {{ form_end(feedbackForm) }}
        </div>
    {% endif %}
    {% else %}
    <div class="card empty-state" style="border-style:solid;">
        <strong>Pas encore de diagnostic approuvé</strong>
        <p>Un administrateur pourra valider un diagnostic lié à ce signalement.</p>
    </div>
    {% endif %}
</div>

<div class="form-actions" style="border:none;margin-top:0;padding-top:0;">
    <a href="{{ path('app_problemes_export_pdf', {id: probleme.id}) }}" class="btn btn-secondary">Exporter PDF</a>
    {% if probleme.etat != 'CLOTURE' %}
        <a href="{{ path('app_problemes_edit', {id: probleme.id}) }}" class="btn btn-ghost">Modifier</a>
    {% endif %}
    <a href="{{ path('app_problemes_index') }}" class="btn btn-primary">Retour à la liste</a>
</div>
{% endblock %}

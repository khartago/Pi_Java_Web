{% extends 'base.html.twig' %}
{% import '_macros/icons.html.twig' as icons %}

{% block title %}Connexion — FARMTECH{% endblock %}

{% block body_class %}theme-public{% endblock %}

{% block flashes %}{% endblock %}

{% block body %}
<main id="main-content" class="shell shell--narrow" tabindex="-1">
    {% include '_flash.html.twig' %}
    <div class="auth-card">
        <a href="{{ path('app_landing') }}" class="auth-brand" aria-label="FarmTech — accueil">{{ icons.brand_logo('site-logo--auth') }}</a>
        <h1 class="font-display">Connexion</h1>
        <p class="auth-lead">Espace <strong>agriculteurs</strong> et <strong>administration</strong> — utilisez l’e-mail et le mot de passe enregistrés en base.</p>
        {% if error %}
            <div class="alert alert-danger" role="alert">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}
        <form method="post" action="{{ path('app_login') }}" data-turbo="false">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            <div class="form-row">
                <label for="username">E-mail</label>
                <input class="form-control" type="email" id="username" name="_username" value="{{ last_username }}" autocomplete="email" required autofocus>
            </div>
            <div class="form-row">
                <label for="password">Mot de passe</label>
                <input class="form-control" type="password" id="password" name="_password" autocomplete="current-password" required>
            </div>
            <button class="btn btn-primary" type="submit" style="width:100%;">Se connecter</button>
        </form>
        <p style="margin-top:1.5rem;text-align:center;color:var(--color-muted);font-size:0.95rem;">
            Pas de compte ? <a href="{{ path('app_register') }}">Créer un compte agriculteur</a>
        </p>
    </div>
</main>
{% endblock %}

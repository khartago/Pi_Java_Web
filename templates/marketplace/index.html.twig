{% extends 'base_front.html.twig' %}

{% block title %}Marketplace | Farmtech{% endblock %}

{% block body %}
    <div class="page-grid marketplace-page">
        <section class="hero marketplace-hero">
            <article class="hero__card marketplace-hero__card">
                <p class="hero__eyebrow">Marketplace</p>
                <h1 class="hero__title">Parcourir les produits, les materiels et leurs categories.</h1>
                <p class="hero__copy">
                    Cette vue expose un catalogue lisible pour les utilisateurs finaux : chaque carte produit affiche
                    sa categorie calculee, le stock disponible et les materiels associes, sans modifier le moteur
                    de gestion interne.
                </p>
                <div class="hero__actions">
                    <a class="button" href="{{ path('app_produit_index') }}">Ouvrir le stock interne</a>
                    <a class="button-ghost" href="{{ path('app_produit_new') }}">Ajouter un produit</a>
                </div>
            </article>

            <aside class="stats-strip" aria-label="Synthese marketplace">
                <h2 class="stats-strip__title">Indicateurs</h2>
                <div class="stats-grid">
                    <article class="stat-chip">
                        <span class="stat-chip__label">Produits visibles</span>
                        <span class="stat-chip__value">{{ cards|length }}</span>
                    </article>
                    <article class="stat-chip">
                        <span class="stat-chip__label">Categories actives</span>
                        <span class="stat-chip__value">{{ category_facets|length }}</span>
                    </article>
                    <article class="stat-chip">
                        <span class="stat-chip__label">Materiels visibles</span>
                        <span class="stat-chip__value">{{ materiel_total }}</span>
                    </article>
                </div>
            </aside>
        </section>

        <section class="panel">
            <div class="panel__header">
                <div>
                    <h2 class="panel__title">Filtrer le catalogue</h2>
                    <p class="panel__copy">Recherche par nom, unite ou categorie. Les filtres restent dans l'URL pour partager facilement la vue courante.</p>
                </div>
            </div>

            <form method="get" action="{{ path('app_marketplace_index') }}" class="filters marketplace-filters">
                <div class="field-group">
                    <label for="recherche">Recherche produit</label>
                    <input class="input" id="recherche" name="recherche" type="search" value="{{ recherche }}" placeholder="Ex: semence, lait, engrais">
                </div>

                <div class="field-group">
                    <label for="unite">Unite</label>
                    <select class="select" id="unite" name="unite">
                        <option value="">Toutes</option>
                        {% for item in unites %}
                            <option value="{{ item }}" {{ unite == item ? 'selected' }}>{{ item }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="field-group">
                    <label for="categorie">Categorie</label>
                    <select class="select" id="categorie" name="categorie">
                        <option value="">Toutes</option>
                        {% for facet in category_facets %}
                            <option value="{{ facet.name }}" {{ categorie == facet.name ? 'selected' }}>{{ facet.name }}</option>
                        {% endfor %}
                    </select>
                </div>

                <button class="button" type="submit">Filtrer</button>
                <a class="button-ghost" href="{{ path('app_marketplace_index') }}">Reinitialiser</a>
            </form>
        </section>

        <section class="panel marketplace-categories" aria-label="Categories du marketplace">
            <div class="panel__header">
                <div>
                    <h2 class="panel__title">Categories</h2>
                    <p class="panel__copy">Chaque categorie est calculee automatiquement a partir des donnees produit deja existantes.</p>
                </div>
            </div>

            <div class="market-chip-row">
                <a
                    class="market-chip {{ categorie == '' ? 'is-active' }}"
                    href="{{ path('app_marketplace_index', { recherche: recherche ?: null, unite: unite ?: null }) }}"
                >
                    Toutes <span>{{ total_products }}</span>
                </a>

                {% for facet in category_facets %}
                    <a
                        class="market-chip {{ categorie == facet.name ? 'is-active' }}"
                        href="{{ path('app_marketplace_index', { recherche: recherche ?: null, unite: unite ?: null, categorie: facet.name }) }}"
                    >
                        {{ facet.name }} <span>{{ facet.count }}</span>
                    </a>
                {% endfor %}
            </div>
        </section>

        {% if cards is empty %}
            <section class="empty-state">
                <h3>Aucun produit ne correspond aux filtres</h3>
                <p>Essayez une autre combinaison de recherche ou revenez a toutes les categories.</p>
                <a class="button" href="{{ path('app_marketplace_index') }}">Voir tout le catalogue</a>
            </section>
        {% else %}
            <p class="pagination-summary">
                {{ pagination.from }}–{{ pagination.to }} sur {{ pagination.total_items }} produit{{ pagination.total_items > 1 ? 's' }}
            </p>

            <section class="market-grid" aria-label="Grille des produits marketplace" data-controller="favorites-filter">
                <div class="market-toolbar">
                    <button type="button"
                            class="fav-filter-toggle"
                            data-favorites-filter-target="toggle"
                            data-action="favorites-filter#toggle"
                            aria-pressed="false">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                        </svg>
                        Favoris uniquement
                    </button>
                </div>

                <p class="market-empty-favs" hidden>Aucun favori parmi les produits affichés. Désactivez le filtre ou ajoutez des favoris.</p>

                {% for card in cards %}
                    <article class="market-card" data-product-id="{{ card.produit.idProduit }}">
                        <figure class="market-card__media">
                            <img
                                src="{{ asset(card.produit.imageAssetPath) }}"
                                alt="Image du produit {{ card.produit.nom }}"
                                loading="lazy"
                            >
                        </figure>

                        <button type="button"
                                class="market-card__star"
                                data-controller="favorite-btn"
                                data-favorite-btn-product-id-value="{{ card.produit.idProduit }}"
                                data-action="favorite-btn#toggle"
                                aria-pressed="false"
                                aria-label="Ajouter aux favoris">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                            </svg>
                        </button>

                        {% if card.promotion %}
                            <div class="market-card__promo-badge">
                                <span class="market-card__promo-label">{{ card.promotion.label }}</span>
                                <span class="market-card__promo-name">{{ card.promotion.nom }}</span>
                            </div>
                        {% endif %}

                        <header class="market-card__head">
                            <p class="market-card__category">{{ card.category }}</p>
                            <span class="product-link__pill">{{ card.produit.dateExpirationLabel }}</span>
                        </header>

                        <h2 class="market-card__title">{{ card.produit.nom }}</h2>
                        <p class="market-card__meta">{{ card.produit.quantite }} {{ card.produit.unite }} disponibles</p>

                        {% if card.produit.prix %}
                            <p class="market-card__price">
                                {% if card.discountedPrice and card.discountedPrice < card.produit.prix %}
                                    <span class="market-card__price--old">{{ card.produit.prix|number_format(2, ',', ' ') }} €</span>
                                    <span class="market-card__price--new">{{ card.discountedPrice|number_format(2, ',', ' ') }} €</span>
                                {% else %}
                                    {{ card.produit.prix|number_format(2, ',', ' ') }} €
                                {% endif %}
                            </p>
                        {% endif %}

                        <dl class="market-card__stats">
                            <div>
                                <dt>Materiels</dt>
                                <dd>{{ card.materielCount }}</dd>
                            </div>
                            <div>
                                <dt>Produit</dt>
                                <dd>#{{ card.produit.idProduit }}</dd>
                            </div>
                        </dl>

                        {% if card.materielPreview is empty %}
                            <p class="market-card__empty">Aucun materiel lie a ce produit.</p>
                        {% else %}
                            <ul class="market-card__list">
                                {% for materielName in card.materielPreview %}
                                    <li>{{ materielName }}</li>
                                {% endfor %}
                            </ul>
                        {% endif %}

                        <div class="market-card__actions">
                            <a class="button-ghost" href="{{ path('app_marketplace_show', { idProduit: card.produit.idProduit }) }}">Voir la fiche</a>
                            <a class="button" href="{{ path('app_materiel_new', { idProduit: card.produit.idProduit }) }}">Ajouter materiel</a>
                        </div>
                    </article>
                {% endfor %}
            </section>

            {% if pagination.total_pages > 1 %}
                {% set query_base = { recherche: recherche ?: null, unite: unite ?: null, categorie: categorie ?: null } %}
                <nav class="pagination" aria-label="Pagination du catalogue">
                    {# Previous #}
                    {% if pagination.page > 1 %}
                        <a class="pagination__btn" href="{{ path('app_marketplace_index', query_base|merge({ page: pagination.page - 1 })) }}" aria-label="Page précédente">
                            ← Précédent
                        </a>
                    {% else %}
                        <span class="pagination__btn is-disabled" aria-disabled="true">← Précédent</span>
                    {% endif %}

                    {# Page numbers — compact window around current page #}
                    <div class="pagination__pages">
                        {% set start = max(1, pagination.page - 2) %}
                        {% set end = min(pagination.total_pages, pagination.page + 2) %}

                        {% if start > 1 %}
                            <a class="pagination__page" href="{{ path('app_marketplace_index', query_base|merge({ page: 1 })) }}">1</a>
                            {% if start > 2 %}<span class="pagination__ellipsis">…</span>{% endif %}
                        {% endif %}

                        {% for p in start..end %}
                            {% if p == pagination.page %}
                                <span class="pagination__page is-current" aria-current="page">{{ p }}</span>
                            {% else %}
                                <a class="pagination__page" href="{{ path('app_marketplace_index', query_base|merge({ page: p })) }}">{{ p }}</a>
                            {% endif %}
                        {% endfor %}

                        {% if end < pagination.total_pages %}
                            {% if end < pagination.total_pages - 1 %}<span class="pagination__ellipsis">…</span>{% endif %}
                            <a class="pagination__page" href="{{ path('app_marketplace_index', query_base|merge({ page: pagination.total_pages })) }}">{{ pagination.total_pages }}</a>
                        {% endif %}
                    </div>

                    {# Next #}
                    {% if pagination.page < pagination.total_pages %}
                        <a class="pagination__btn" href="{{ path('app_marketplace_index', query_base|merge({ page: pagination.page + 1 })) }}" aria-label="Page suivante">
                            Suivant →
                        </a>
                    {% else %}
                        <span class="pagination__btn is-disabled" aria-disabled="true">Suivant →</span>
                    {% endif %}
                </nav>
            {% endif %}
        {% endif %}
    </div>
{% endblock %}

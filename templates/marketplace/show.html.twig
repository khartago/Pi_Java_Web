{% extends 'base_front.html.twig' %}

{% block title %}{{ produit.nom }} | FarmTech Marketplace{% endblock %}

{% block body %}
<div class="page-grid product-detail-page">

    {# Breadcrumb #}
    <nav class="breadcrumb" aria-label="Fil d'Ariane">
        <a href="{{ path('app_marketplace_index') }}">Catalogue</a>
        <span aria-hidden="true">›</span>
        <a href="{{ path('app_marketplace_index', { categorie: category }) }}">{{ category }}</a>
        <span aria-hidden="true">›</span>
        <span class="breadcrumb__current">{{ produit.nom }}</span>
    </nav>

    {# Hero produit : image + infos #}
    <section class="product-hero">
        <figure class="product-hero__media">
            <img src="{{ asset(produit.imageAssetPath) }}" alt="{{ produit.nom }}" loading="eager">
            {% if promotion %}
                <div class="product-hero__promo-ribbon">
                    <span class="product-hero__promo-label">{{ promotion.label }}</span>
                    <span class="product-hero__promo-name">{{ promotion.nom }}</span>
                </div>
            {% endif %}
        </figure>

        <article class="product-hero__info">
            <p class="product-hero__category">{{ category }}</p>
            <h1 class="product-hero__title">{{ produit.nom }}</h1>

            <div class="product-hero__meta">
                <span class="product-hero__chip">
                    <strong>{{ produit.quantite }}</strong> {{ produit.unite }} disponibles
                </span>
                {% if produit.dateExpiration %}
                    <span class="product-hero__chip product-hero__chip--soft">
                        Expire le {{ produit.dateExpirationLabel }}
                    </span>
                {% endif %}
            </div>

            {% if produit.prix is not null %}
                <div class="product-hero__pricing">
                    {% if discountedPrice is not null and discountedPrice < produit.prix %}
                        <span class="product-hero__price product-hero__price--old">{{ produit.prix|number_format(2, ',', ' ') }} €</span>
                        <span class="product-hero__price product-hero__price--new">{{ discountedPrice|number_format(2, ',', ' ') }} €</span>
                        <span class="product-hero__savings">
                            Économie : {{ (produit.prix - discountedPrice)|number_format(2, ',', ' ') }} €
                        </span>
                    {% else %}
                        <span class="product-hero__price">{{ produit.prix|number_format(2, ',', ' ') }} €</span>
                    {% endif %}
                    <span class="product-hero__price-unit">/ {{ produit.unite }}</span>
                </div>
            {% else %}
                <p class="product-hero__no-price">Prix non communiqué</p>
            {% endif %}

            <div class="product-hero__actions">
                <button type="button"
                        class="button product-hero__fav-btn"
                        data-controller="favorite-btn"
                        data-favorite-btn-product-id-value="{{ produit.idProduit }}"
                        data-action="favorite-btn#toggle"
                        aria-pressed="false"
                        aria-label="Ajouter aux favoris">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                    </svg>
                    Ajouter aux favoris
                </button>
                <a class="button-ghost" href="{{ path('app_marketplace_index') }}">← Retour catalogue</a>
            </div>
        </article>
    </section>

    {# Détails et matériels associés #}
    <div class="product-detail-grid">

        <section class="panel">
            <div class="panel__header">
                <h2 class="panel__title">Informations produit</h2>
            </div>
            <dl class="product-detail-specs">
                <div>
                    <dt>Référence</dt>
                    <dd>#{{ produit.idProduit }}</dd>
                </div>
                <div>
                    <dt>Catégorie</dt>
                    <dd>{{ category }}</dd>
                </div>
                <div>
                    <dt>Stock disponible</dt>
                    <dd>{{ produit.quantite }} {{ produit.unite }}</dd>
                </div>
                <div>
                    <dt>Date d'expiration</dt>
                    <dd>{{ produit.dateExpirationLabel }}</dd>
                </div>
                {% if produit.prix is not null %}
                    <div>
                        <dt>Prix unitaire</dt>
                        <dd>{{ produit.prix|number_format(2, ',', ' ') }} € / {{ produit.unite }}</dd>
                    </div>
                {% endif %}
                <div>
                    <dt>Matériels associés</dt>
                    <dd>{{ produit.materiels|length }}</dd>
                </div>
            </dl>
        </section>

        <section class="panel">
            <div class="panel__header">
                <h2 class="panel__title">Matériels associés</h2>
                <p class="panel__copy">Équipement requis ou compatible avec ce produit.</p>
            </div>

            {% if produit.materiels is empty %}
                <p class="product-detail-empty">Aucun matériel associé à ce produit.</p>
            {% else %}
                <ul class="product-detail-materiels">
                    {% for m in produit.materiels %}
                        <li class="product-detail-materiels__item">
                            <span class="product-detail-materiels__name">{{ m.nom }}</span>
                            <span class="product-detail-materiels__state product-detail-materiels__state--{{ m.etat }}">{{ m.etat }}</span>
                        </li>
                    {% endfor %}
                </ul>
            {% endif %}
        </section>

        {% if promotion %}
            <section class="panel product-detail-promo">
                <div class="panel__header">
                    <h2 class="panel__title">🏷️ Promotion en cours</h2>
                </div>
                <h3 class="product-detail-promo__name">{{ promotion.nom }}</h3>
                {% if promotion.description %}
                    <p class="product-detail-promo__desc">{{ promotion.description }}</p>
                {% endif %}
                <ul class="product-detail-promo__list">
                    <li><strong>Réduction :</strong> {{ promotion.label }}</li>
                    <li><strong>Valable jusqu'au :</strong> {{ promotion.dateFin|date('d/m/Y') }}</li>
                    {% if promotion.quantiteMin > 1 %}
                        <li><strong>Quantité minimale :</strong> {{ promotion.quantiteMin }} {{ produit.unite }}</li>
                    {% endif %}
                    {% if not promotion.cumulable %}
                        <li class="product-detail-promo__warning">⚠ Non cumulable avec d'autres promotions</li>
                    {% endif %}
                </ul>
            </section>
        {% endif %}

    </div>

    {# 🤖 Matériels recommandés (algorithme intelligent multi-critères) #}
    {% if recommendations is not empty %}
        <section class="panel reco-section">
            <div class="panel__header">
                <div>
                    <h2 class="panel__title">
                        <span class="reco-section__sparkle">✨</span>
                        Matériels recommandés pour ce produit
                    </h2>
                    <p class="panel__copy">
                        Sélection automatique basée sur 6 critères : catégorie, unité, mots-clés,
                        état, disponibilité et ancienneté.
                    </p>
                </div>
                <span class="reco-section__count">{{ recommendations|length }} suggestion{{ recommendations|length > 1 ? 's' }}</span>
            </div>

            <div class="reco-grid">
                {% for r in recommendations %}
                    {% set m = r.materiel %}
                    <article class="reco-card reco-card--rank-{{ loop.index }} {{ r.curated ? 'reco-card--curated' }}">
                        {% if r.curated %}
                            <div class="reco-card__curated-badge">
                                <span>👨‍💼 Recommandation du gérant</span>
                                <span class="reco-card__curated-priority">{{ r.priorityLabel }}</span>
                            </div>
                        {% endif %}
                        <header class="reco-card__head">
                            <div class="reco-card__rank">#{{ loop.index }}</div>
                            <div class="reco-card__score">
                                <span class="reco-card__score-value">{{ r.matchPercent }}<span>%</span></span>
                                <span class="reco-card__score-label">match</span>
                            </div>
                        </header>

                        <div class="reco-card__bar">
                            <div class="reco-card__bar-fill" style="width: {{ r.matchPercent }}%;"></div>
                        </div>

                        <h3 class="reco-card__name">{{ m.nom }}</h3>

                        <div class="reco-card__pills">
                            <span class="reco-pill reco-pill--state-{{ m.etat }}">{{ m.etat }}</span>
                            {% if m.produit %}
                                <span class="reco-pill reco-pill--soft">
                                    Lié à <a href="{{ path('app_marketplace_show', { idProduit: m.produit.idProduit }) }}">{{ m.produit.nom }}</a>
                                </span>
                            {% endif %}
                            {% if m.cout %}
                                <span class="reco-pill reco-pill--soft">{{ m.cout|number_format(0, ',', ' ') }} €</span>
                            {% endif %}
                        </div>

                        {% if r.adminReason %}
                            <blockquote class="reco-card__admin-note">{{ r.adminReason }}</blockquote>
                        {% endif %}

                        <details class="reco-card__why">
                            <summary>Pourquoi ce matériel ?</summary>
                            <ul class="reco-card__reasons">
                                {% for reason in r.reasons %}
                                    <li>
                                        <span class="reco-reason__icon">{{ reason.icon }}</span>
                                        <span>{{ reason.label }}</span>
                                    </li>
                                {% endfor %}
                            </ul>
                        </details>
                    </article>
                {% endfor %}
            </div>

            <p class="reco-section__legend">
                <strong>Comment ça marche ?</strong>
                Chaque matériel reçoit un score (max 100) calculé en temps réel.
                Catégorie identique : <em>+35 pts</em> · Bon état : <em>+18 pts</em> ·
                Disponible : <em>+10 pts</em> · Récent : <em>+5 pts</em>. Les matériels en panne sont exclus.
            </p>
        </section>
    {% endif %}

    {# Produits similaires #}
    {% if related is not empty %}
        <section class="panel">
            <div class="panel__header">
                <h2 class="panel__title">Vous aimerez aussi</h2>
            </div>
            <div class="related-grid">
                {% for r in related %}
                    <a class="related-card" href="{{ path('app_marketplace_show', { idProduit: r.idProduit }) }}">
                        <figure class="related-card__media">
                            <img src="{{ asset(r.imageAssetPath) }}" alt="{{ r.nom }}" loading="lazy">
                        </figure>
                        <div class="related-card__body">
                            <h3 class="related-card__title">{{ r.nom }}</h3>
                            <p class="related-card__meta">{{ r.quantite }} {{ r.unite }}</p>
                            {% if r.prix is not null %}
                                <p class="related-card__price">{{ r.prix|number_format(2, ',', ' ') }} €</p>
                            {% endif %}
                        </div>
                    </a>
                {% endfor %}
            </div>
        </section>
    {% endif %}

</div>
{% endblock %}

{% extends 'admin/layout.html.twig' %}

{% block title %}Modifier production{% endblock %}

{% block admin_content %}
    <section class="admin-card">
        <p class="page-eyebrow">Production</p>
        <h1>Modifier production #{{ production.idProduction }}</h1>
        <p class="page-lead">Ajustez les informations de recolte et l'etat du lot.</p>
        {{ form_start(form) }}
            <div class="form-row">{{ form_row(form.quantiteProduite) }}</div>
            <div class="form-row">{{ form_row(form.dateRecolte) }}</div>
            <div class="form-row">{{ form_row(form.qualite) }}</div>
            <div class="form-row">{{ form_row(form.etat) }}</div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Enregistrer</button>
                <a href="{{ path('app_production_index') }}" class="btn btn-ghost">Retour</a>
            </div>
        {{ form_end(form) }}
    </section>
{% endblock %}

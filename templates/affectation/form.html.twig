{% extends 'base_admin.html.twig' %}

{% block title %}Nouvelle affectation | Farmtech{% endblock %}

{% block body %}
<section class="sheet-layout">
    <aside class="sheet-backdrop">
        <p class="hero__eyebrow">Gestion des affectations</p>
        <h2>Affecter un matériel</h2>
        <p>
            Associez un matériel disponible à un employé. Seuls les matériels qui ne sont pas en panne
            et ne disposant pas déjà d'une affectation active peuvent être sélectionnés.
        </p>
        <div style="margin-top: 20px;">
            <a class="button-ghost" href="{{ path('app_affectation_index') }}">Retour aux affectations</a>
        </div>
    </aside>

    <article class="sheet">
        <div class="sheet__header">
            <div>
                <h1 class="sheet__title">Nouvelle affectation</h1>
                <p class="sheet__copy">
                    Renseignez le matériel, l'employé destinataire et la date d'entrée en service.
                </p>
            </div>
            <a class="button-ghost" href="{{ path('app_affectation_index') }}">Annuler</a>
        </div>

        {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}

            {% if not form.vars.valid %}
                <div class="form-errors">
                    {{ form_errors(form) }}
                </div>
            {% endif %}

            <div class="form-grid">

                <div class="field-group">
                    {{ form_label(form.materiel) }}
                    {{ form_widget(form.materiel) }}
                    {% for error in form.materiel.vars.errors %}
                        <p class="field-error">{{ error.message }}</p>
                    {% endfor %}
                    <p class="help-text">Seuls les matériels dont l'état n'est pas "panne" sont listés.</p>
                </div>

                <div class="field-group">
                    {{ form_label(form.employe) }}
                    {{ form_widget(form.employe) }}
                    {% for error in form.employe.vars.errors %}
                        <p class="field-error">{{ error.message }}</p>
                    {% endfor %}
                    <p class="help-text">
                        L'employé n'est pas dans la liste ?
                        <a class="link-button" href="{{ path('app_employe_new') }}">Ajouter un employé</a>
                    </p>
                </div>

                <div class="field-group">
                    {{ form_label(form.dateAffectation) }}
                    {{ form_widget(form.dateAffectation) }}
                    {% for error in form.dateAffectation.vars.errors %}
                        <p class="field-error">{{ error.message }}</p>
                    {% endfor %}
                </div>

                <div class="field-group">
                    {{ form_label(form.note) }}
                    {{ form_widget(form.note) }}
                    {% for error in form.note.vars.errors %}
                        <p class="field-error">{{ error.message }}</p>
                    {% endfor %}
                </div>

            </div>

            <div class="form-actions">
                <p class="help-text">Le retour du matériel pourra être enregistré depuis la liste des affectations actives.</p>
                <div class="detail-panel__actions">
                    <a class="button-ghost" href="{{ path('app_affectation_index') }}">Annuler</a>
                    <button class="button" type="submit">Enregistrer l'affectation</button>
                </div>
            </div>

        {{ form_end(form) }}
    </article>
</section>
{% endblock %}

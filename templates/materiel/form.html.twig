{% extends 'base.html.twig' %}

{% block title %}
    {{ mode == 'creation' ? 'Nouveau matériel' : 'Modifier le matériel' }} | Farmtech
{% endblock %}

{% block body %}
    <section class="sheet-layout">
        <aside class="sheet-backdrop">
            <p class="hero__eyebrow">Gestion matériel</p>
            <h2>{{ mode == 'creation' ? 'Ajouter un matériel' : 'Modifier un matériel' }}</h2>
            <p>
                Le flux reste volontairement centré sur le produit <strong>{{ produit.nom }}</strong> pour éviter une gestion dispersée des équipements.
            </p>
        </aside>

        <article class="sheet">
            <div class="sheet__header">
                <div>
                    <h1 class="sheet__title">{{ mode == 'creation' ? 'Nouveau matériel' : materiel.nom }}</h1>
                    <p class="sheet__copy">
                        Ce matériel sera enregistré sous le produit <strong>{{ produit.nom }}</strong> et réapparaîtra directement dans sa fiche.
                    </p>
                </div>

                <a class="button-ghost" href="{{ path('app_produit_show', { idProduit: produit.idProduit }) }}">Retour</a>
            </div>

            {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}
                {% if not form.vars.valid %}
                    <div class="form-errors">
                        {{ form_errors(form) }}
                    </div>
                {% endif %}

                <div class="form-grid form-grid--two">
                    <div class="field-group">
                        {{ form_label(form.nom) }}
                        {{ form_widget(form.nom) }}
                        {% for error in form.nom.vars.errors %}
                            <p class="field-error">{{ error.message }}</p>
                        {% endfor %}
                    </div>

                    <div class="field-group">
                        {{ form_label(form.etat) }}
                        {{ form_widget(form.etat) }}
                        {% for error in form.etat.vars.errors %}
                            <p class="field-error">{{ error.message }}</p>
                        {% endfor %}
                    </div>

                    <div class="field-group">
                        {{ form_label(form.dateAchat) }}
                        {{ form_widget(form.dateAchat) }}
                        {% for error in form.dateAchat.vars.errors %}
                            <p class="field-error">{{ error.message }}</p>
                        {% endfor %}
                    </div>

                    <div class="field-group">
                        {{ form_label(form.cout) }}
                        {{ form_widget(form.cout) }}
                        {% for error in form.cout.vars.errors %}
                            <p class="field-error">{{ error.message }}</p>
                        {% endfor %}
                    </div>
                </div>

                <div class="form-actions">
                    <p class="help-text">Le matériel est toujours créé ou modifié depuis un contexte produit.</p>

                    <div class="detail-panel__actions">
                        <a class="button-ghost" href="{{ path('app_produit_show', { idProduit: produit.idProduit }) }}">Annuler</a>
                        <button class="button" type="submit">{{ submit_label }}</button>
                    </div>
                </div>
            {{ form_end(form) }}
        </article>
    </section>
{% endblock %}

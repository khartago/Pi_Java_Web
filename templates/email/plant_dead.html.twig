{% block body %}
<div style="
    background: #f4f6f8;
    padding: 30px;
    font-family: Arial, sans-serif;
">

    <!-- CARD -->
    <div style="
        max-width: 500px;
        margin: auto;
        background: #ffffff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    ">

        <!-- HEADER -->
        <div style="
            background: linear-gradient(135deg, #ff6b6b, #e74c3c);
            color: white;
            padding: 20px;
            text-align: center;
        ">
            <h2 style="margin: 0;">🌱 Plant Alert</h2>
        </div>

        <!-- BODY -->
        <div style="padding: 25px; color: #333;">
            
            <p style="font-size: 16px;">Hello <strong>{{ user ?? 'Farmer' }}</strong>,</p>

            <p style="font-size: 15px;">
                Your plant 
                <strong style="color:#e74c3c;">
                    {{ plantName ?? 'Unknown' }}
                </strong> 
                has died.
            </p>

            <!-- INFO BOX -->
            <div style="
                background: #f9f9f9;
                border-left: 4px solid #e74c3c;
                padding: 12px;
                margin: 20px 0;
                border-radius: 6px;
            ">
                🌡️ Temperature: <strong>{{ temp ?? 'N/A' }} °C</strong><br>
                💧 Check watering and plant care.
            </div>

            <p style="font-size: 14px; color: #666;">
                Please take action to maintain your farm health.
            </p>

        </div>

        <!-- FOOTER -->
        <div style="
            background: #f1f1f1;
            text-align: center;
            padding: 15px;
            font-size: 12px;
            color: #888;
        ">
            FarmTech 🌾 • Smart Agriculture System<br>
            © 2026 All rights reserved
        </div>

    </div>

</div>
{% endblock %}
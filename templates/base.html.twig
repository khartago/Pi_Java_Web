<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Farmtech Stock{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2282%22>F</text></svg>">
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        <header class="site-header">
            <div class="site-header__inner">
                <a class="brand" href="{{ path('app_produit_index') }}">
                    <span class="brand__badge">FT</span>
                    <span class="brand__copy">
                        <span class="brand__eyebrow">Farmtech</span>
                        <span class="brand__title">Produits & matériels</span>
                        <span class="brand__subtitle">Port web Symfony du module Java</span>
                    </span>
                </a>

                <nav class="site-nav" aria-label="Navigation principale">
                    {% set current_route = app.request.attributes.get('_route')|default('') %}
                    <a class="nav-pill {{ current_route starts with 'app_marketplace_' ? 'is-active' }}" href="{{ path('app_marketplace_index') }}">
                        Marketplace
                    </a>
                    <a class="nav-pill {{ current_route starts with 'app_produit_' or current_route starts with 'app_materiel_' ? 'is-active' }}" href="{{ path('app_produit_index') }}">
                        Stock interne
                    </a>
                </nav>
            </div>
        </header>

        <main class="shell">
            {% include 'components/_flash.html.twig' %}
            {% block body %}{% endblock %}
        </main>
    </body>
</html>

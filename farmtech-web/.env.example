# Copier vers .env ou .env.local et ajuster (ne pas committer de secrets réels).
#
# Après mise à jour : `php bin/console doctrine:migrations:migrate` (inclut les tables blog / article / commentaire).
#
# --- Parité JavaFX (pidev-3a19) ---
# Le client JavaFX lit la même base via JDBC. Utiliser le MÊME nom de schéma MySQL que
# dans DATABASE_URL ci-dessous et que dans `src/main/resources/database.properties` du
# module Java (voir docs/WEB_JAVAFX_PARITY.md à la racine du dépôt).
#
# Symfony
APP_ENV=dev
APP_SECRET=change_me_generate_a_random_secret
DATABASE_URL="mysql://root:@127.0.0.1:3306/3a19?serverVersion=10.11.0-MariaDB&charset=utf8mb4"
MAILER_DSN=null://null
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

# Actualités agricoles (NewsAPI — page /news)
NEWS_API_KEY=

# Météo (clé API tierce si utilisée par WebWeatherService)
WEATHER_API_KEY=

# Assistant / diagnostic IA (optionnel)
ASSISTANT_API_KEY=
ASSISTANT_BASE_URL=https://api.openai.com/v1
ASSISTANT_MODEL=gpt-4o-mini

# OpenAI direct (client Java marketplace OpenAiChatService ; optionnel si vous utilisez openai.api.key dans pidev config.properties)
# OPENAI_API_KEY=

OPENROUTER_API_KEY=
OPENROUTER_CHAT_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it

# PDF distant (export rapports)
PDF_REMOTE_URL=https://html2pdf.fly.dev/api/generate

# Alertes stock / email jeu
STOCK_ALERT_THRESHOLD=5
ALERT_EMAIL_FROM=alerts@farmtech.local
ALERT_EMAIL_TO=admin@farmtech.local
GAME_MAIL_FROM=alerts@farmtech.local
GAME_MAIL_TO=admin@farmtech.local

# Coordonnées par défaut (météo)
WEATHER_DEFAULT_LAT=36.8065
WEATHER_DEFAULT_LON=10.1815

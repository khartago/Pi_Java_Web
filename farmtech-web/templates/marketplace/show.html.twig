{% extends 'front/layout.html.twig' %}

{% block title %}{{ produit.nom }} | Marketplace{% endblock %}

{% block front_content %}
    <section class="farm-card">
        <a href="{{ path('app_marketplace_index') }}">← Retour marketplace</a>
        <div class="market-detail">
            <img
                src="{{ asset(produit.imageAssetPath) }}"
                alt="{{ produit.nom }}"
                class="admin-media"
                onerror="this.onerror=null;this.src='{{ asset('images/product-placeholder.svg') }}';"
            >
            <div>
                <h1>{{ produit.nom }}</h1>
                <p class="page-lead">Categorie: {{ category }}</p>
                <div class="admin-meta-grid">
                    <div class="admin-meta-chip"><strong>Quantite:</strong> {{ produit.quantite }} {{ produit.unite }}</div>
                    <div class="admin-meta-chip"><strong>Expiration:</strong> {{ produit.dateExpirationLabel }}</div>
                    <div class="admin-meta-chip"><strong>Prix:</strong> {{ produit.prix is not null ? produit.prix|number_format(2, ',', ' ') ~ ' TND' : '-' }}</div>
                </div>

                <h3>Materiels associes</h3>
                <ul class="admin-simple-list">
                    {% for materiel in produit.materiels %}
                        <li>{{ materiel.nom }} — {{ materiel.etat }}</li>
                    {% else %}
                        <li>Aucun materiel associe.</li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    </section>
{% endblock %}

{% extends 'front/layout.html.twig' %}

{% block title %}{{ form.vars.value.id ? 'Modifier le commentaire' : 'Nouveau commentaire' }} — FARMTECH{% endblock %}

{% block front_content %}
<div class="farmer-dashboard" style="max-width: 640px; margin: 0 auto;">

    <article class="farmer-home-card">
        <div class="farmer-home-card__intro p-3">
            <a href="{{ path('app_article_show', {'idArticle': article.id}) }}" class="btn btn-ghost mb-3" style="padding-left: 0;">&larr; Retour à l'article</a>
            <header class="farmer-home-card__head">
                <h1 class="farmer-home-card__title">
                    {% if form.vars.value.id %}Modifier le commentaire{% else %}Laisser un commentaire{% endif %}
                </h1>
                <p class="farmer-home-card__lead text-muted small mb-0">Article : {{ article.title }}</p>
            </header>
        </div>
    </article>

    <article class="farmer-home-card mt-4">
        <div class="farmer-home-card__intro p-3">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                <div class="mb-3">
                    {{ form_label(form.contenu, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
                    {{ form_widget(form.contenu, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.contenu) }}
                </div>
                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a href="{{ path('app_article_show', {'idArticle': article.id}) }}" class="btn btn-ghost">Annuler</a>
                    <button type="submit" class="btn btn-primary">Enregistrer</button>
                </div>
            {{ form_end(form) }}
        </div>
    </article>

</div>
{% endblock %}

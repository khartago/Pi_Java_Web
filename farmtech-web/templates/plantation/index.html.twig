{% extends 'admin/layout.html.twig' %}

{% block title %}Plantations{% endblock %}

{% block admin_content %}
    <section class="admin-card">
        <p class="page-eyebrow">Plantation</p>
        <div class="admin-card-header">
            <h1>Gestion des plantations</h1>
            <a href="{{ path('app_plantation_new') }}" class="btn btn-primary">Nouvelle plantation</a>
        </div>
        <p class="page-lead">Recherchez, triez et validez les plantations avant passage en production.</p>

        <form method="get" class="filters-inline">
            <input type="search" name="q" class="form-control" value="{{ keyword }}" placeholder="Recherche nom / variete / saison">
            <select name="sort" class="form-control">
                <option value="">Tri par defaut</option>
                <option value="quantite" {{ sort == 'quantite' ? 'selected' }}>Quantite</option>
                <option value="date" {{ sort == 'date' ? 'selected' }}>Date</option>
            </select>
            <button type="submit" class="btn">Filtrer</button>
            <a href="{{ path('app_plantation_index') }}" class="btn btn-ghost">Reset</a>
        </form>

        <div class="stats-grid stats-grid--compact">
            <article class="stat-card"><span class="lbl">Total</span><span class="val">{{ stats.total }}</span></article>
            <article class="stat-card"><span class="lbl">Completes</span><span class="val">{{ stats.complete }}</span></article>
            <article class="stat-card"><span class="lbl">En attente</span><span class="val">{{ stats.attente }}</span></article>
        </div>

        <div class="table-responsive">
            <table class="table">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Nom</th>
                    <th>Variete</th>
                    <th>Quantite</th>
                    <th>Date</th>
                    <th>Saison</th>
                    <th>Etat</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for p in plantations %}
                    <tr>
                        <td>{{ p.id }}</td>
                        <td>{{ p.nomPlant }}</td>
                        <td>{{ p.variete }}</td>
                        <td>{{ p.quantite }}</td>
                        <td>{{ p.datePlante|date('Y-m-d') }}</td>
                        <td>{{ p.saison }}</td>
                        <td>
                            <span class="badge {{ p.etat == 'COMPLETE' ? 'badge-info' : 'badge-warn' }}">{{ p.etat }}</span>
                        </td>
                        <td class="actions-inline">
                            <a href="{{ path('app_plantation_edit', {'id': p.id}) }}" class="btn btn-sm btn-ghost">Modifier</a>
                            <form method="post" action="{{ path('app_plantation_delete', {'id': p.id}) }}" style="display:inline;">
                                <button type="submit" class="btn-link" onclick="return confirm('Supprimer cette plantation ?');">Supprimer</button>
                            </form>
                            {% if p.etat == 'EN_ATTENTE' %}
                                <form method="post" action="{{ path('app_plantation_accept', {'id': p.id}) }}" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-primary">Accepter</button>
                                </form>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="8" class="text-muted">Aucune plantation pour ce filtre.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}

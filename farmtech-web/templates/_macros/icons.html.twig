{# Logo FarmTech (asset image / SVG selon déploiement) #}
{% macro brand_logo(css_class, alt) %}
<img src="{{ asset('images/farmtech-logo.png') }}" alt="{{ alt|default('FarmTech') }}" class="site-logo {{ css_class|default('') }}" loading="eager" decoding="async">
{% endmacro %}

{# Icônes SVG (stroke), couleur via currentColor #}
{% macro sprout(size, class) %}
<svg class="icon {{ class|default('') }}" width="{{ size|default(24) }}" height="{{ size|default(24) }}" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path d="M12 22V11" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    <path d="M12 11C8 5 4 6 4 11c0 5 4 8 8 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M12 11c4-6 8-5 8 1 0 5-4 7-8 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
{% endmacro %}


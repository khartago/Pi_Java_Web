{% extends 'front/layout.html.twig' %}

{% block title %}{{ mode == 'creation' ? 'Créer un blog' : 'Modifier le blog' }} — FARMTECH{% endblock %}

{% block front_content %}
<div class="farmer-dashboard" style="max-width: 700px; margin: 0 auto;">

    <article class="farmer-home-card">
        <div class="farmer-home-card__intro">
            <header class="farmer-home-card__head">
                <h1 class="farmer-home-card__title">
                    {% if mode == 'creation' %}Nouveau Blog{% else %}Modifier le Blog{% endif %}
                </h1>
            </header>
        </div>
    </article>

    <article class="farmer-home-card mt-4">
        <div class="farmer-home-card__intro">

            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                <div class="mb-3">
                    {{ form_label(form.titleBlog, 'Titre du blog', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                    {{ form_widget(form.titleBlog, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.titleBlog) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.blogTag, 'Tag / Catégorie', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                    {{ form_widget(form.blogTag, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Agriculture, Élevage...'}}) }}
                    {{ form_errors(form.blogTag) }}
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a href="{{ path('app_news') }}" class="btn btn-ghost">Annuler</a>
                    <button type="submit" class="btn btn-primary">
                        {% if mode == 'creation' %}Créer le blog{% else %}Enregistrer{% endif %}
                    </button>
                </div>

            {{ form_end(form) }}

        </div>
    </article>

</div>
{% endblock %}
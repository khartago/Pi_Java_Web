{% extends 'base.html.twig' %}

{% block title %}All Articles{% endblock %}

{% block body %}
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <h1 class="mb-4">Latest Articles</h1>

            {% for article in articles %}
                <div class="card mb-4 shadow-sm">
                    <div class="card-body">
                        <h2 class="h5 card-title">
                            <a href="{{ path('app_blog_show', {'slug': article.slug}) }}" class="text-decoration-none text-dark">
                                {{ article.title }}
                            </a>
                        </h2>
                        <p class="text-muted small">
                            Posted on {{ article.createdAt|date('M d, Y') }} by {{ article.authorName|default('Anonymous') }}
                        </p>
                        <p class="card-text">
                            {{ article.excerpt|default(article.content|slice(0, 200) ~ '...') }}
                        </p>
                        <a href="{{ path('app_blog_show', {'slug': article.slug}) }}" class="btn btn-sm btn-outline-primary">
                            Read More
                        </a>
                    </div>
                </div>
            {% else %}
                <p>No articles found.</p>
            {% endfor %}
        </div>
    </div>
{% endblock %}
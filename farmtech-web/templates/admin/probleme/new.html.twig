{% extends 'admin/layout.html.twig' %}

{% block title %}Nouveau problème — Admin{% endblock %}

{% block admin_content %}
<section class="page-hero">
    <span class="page-eyebrow">Création</span>
    <h1>Nouveau problème</h1>
    <p class="page-lead">Création d’un signalement depuis l’administration.</p>
</section>
<div class="card form-card form-card--wide">
    {{ form_start(form, {attr: {enctype: 'multipart/form-data'}}) }}
        {{ form_row(form.type) }}
        {{ form_row(form.description) }}
        {{ form_row(form.gravite) }}
        {{ form_row(form.dateDetection) }}
        {{ form_row(form.etat) }}
        {{ form_row(form.photoFiles) }}
        <div class="form-actions">
            <button class="btn btn-primary" type="submit">Créer</button>
            <a href="{{ path('admin_problemes_index') }}" class="btn btn-ghost">Annuler</a>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}

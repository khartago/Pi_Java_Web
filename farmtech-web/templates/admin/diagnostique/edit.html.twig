{% extends 'admin/layout.html.twig' %}

{% block title %}Diagnostic #{{ diagnostic.id }} — Admin{% endblock %}

{% block admin_content %}
<section class="page-hero">
    <span class="page-eyebrow">Édition</span>
    <h1>Diagnostic #{{ diagnostic.id }}</h1>
    <p class="page-lead">Mettre à jour le diagnostic et le retour fermier si présent.</p>
</section>
{% if contextProbleme %}
    {% include '_includes/probleme_context_card.html.twig' with { probleme: contextProbleme } only %}
{% endif %}
<div class="card form-card form-card--wide">
    {{ form_start(form) }}
        {{ form_row(form.probleme) }}
        {{ form_row(form.cause) }}
        {{ form_row(form.solutionProposee) }}
        {{ form_row(form.dateDiagnostique) }}
        {{ form_row(form.resultat) }}
        {{ form_row(form.medicament) }}
        {{ form_row(form.approuve) }}
        {{ form_row(form.numRevision) }}
        {% if form.feedbackFermier is defined %}
            {{ form_row(form.feedbackFermier) }}
            {{ form_row(form.feedbackCommentaire) }}
        {% endif %}
        <div class="form-actions">
            <button class="btn btn-primary" type="submit">Enregistrer</button>
            <a href="{{ path('admin_problemes_index') }}" class="btn btn-ghost">Annuler</a>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}

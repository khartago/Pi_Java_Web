{% extends 'front/layout.html.twig' %}

{% block title %}{{ article.title }} — FARMTECH{% endblock %}

{% block front_content %}
<div class="farmer-dashboard">

    {# Article Details #}
    <article class="farmer-home-card">
        <div class="farmer-home-card__intro">
            <header class="farmer-home-card__head">
                <a href="{{ path('app_blog_show', {'idBlog': article.blogId}) }}" class="btn btn-ghost mb-3" style="padding-left: 0;">
                    &larr; Retour au blog
                </a>
                <h1 class="farmer-home-card__title">{{ article.title }}</h1>
                <p class="farmer-home-card__lead">
                    <small class="text-muted">Publié le {{ article.createdAt|date('d/m/Y à H:i') }}</small>
                    {% if article.edited %}<span class="badge bg-warning text-dark ms-2">Modifié</span>{% endif %}
                </p>
            </header>

            <div class="mt-3 mb-4" style="white-space: pre-wrap; line-height: 1.6;">{{ article.text }}</div>

            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <span class="text-success fw-bold">👍 {{ article.likes|default(0) }}</span>
                    <span class="text-danger fw-bold ms-2">👎 {{ article.dislikes|default(0) }}</span>
                </div>
            </div>

            {# ONLY SHOW EDIT/DELETE IF USER OWNS THE ARTICLE #}
            {% if isOwner %}
            <div class="farmer-home-card__actions border-top pt-3">
                <a href="{{ path('app_article_edit', {'idArticle': article.id}) }}" class="btn btn-ghost">Modifier l'article</a>
                <form method="POST" action="{{ path('app_article_delete', {'idArticle': article.id}) }}" style="display: inline;" onsubmit="return confirm('Supprimer cet article et ses commentaires ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete-article-' ~ article.id) }}">
                    <button type="submit" class="btn btn-ghost" style="color: #dc3545;">Supprimer</button>
                </form>
            </div>
            {% endif %}
        </div>
    </article>

    {# Comments Section #}
    <section class="farmer-home-card mt-4">
        <div class="farmer-home-card__intro">
            <header class="farmer-home-card__head">
                <h2 class="farmer-home-card__title">Commentaires</h2>
            </header>
            <div class="farmer-home-card__actions">
                <a href="{{ path('app_commentaire_new', {'idArticle': article.id}) }}" class="btn btn-primary">Laisser un commentaire</a>
            </div>
        </div>

        {% if comments is not empty %}
        <ul class="list-group list-group-flush">
            {% for comment in comments %}
            <li class="list-group-item">
                <div class="d-flex justify-content-between">
                    <div>
                        <strong>{{ comment.utilisateur.nom ?? 'Utilisateur' }}</strong>
                        <small class="text-muted ms-2">{{ comment.dateCommentaire|date('d/m/Y H:i') }}</small>
                        <p class="mt-2 mb-0">{{ comment.contenu }}</p>
                    </div>

                    {# ONLY SHOW EDIT/DELETE IF LOGGED IN USER IS THE COMMENT AUTHOR #}
                    {% if comment.utilisateur.id == app.user.id %}
                    <div class="d-flex flex-nowrap gap-2">
                        <a href="{{ path('app_commentaire_edit', {'id': comment.id}) }}" class="btn btn-sm btn-ghost p-0">Modifier</a>
                        <form method="POST" action="{{ path('app_commentaire_delete', {'id': comment.id}) }}" onsubmit="return confirm('Supprimer ce commentaire ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete-commentaire-' ~ comment.id) }}">
                            <button type="submit" class="btn btn-sm btn-ghost p-0" style="color:#dc3545;">Supprimer</button>
                        </form>
                    </div>
                    {% endif %}
                </div>
            </li>
            {% endfor %}
        </ul>
        {% else %}
        <p class="farmer-home-summary__p mt-3">Aucun commentaire pour le moment.</p>
        {% endif %}
    </section>

</div>
{% endblock %}
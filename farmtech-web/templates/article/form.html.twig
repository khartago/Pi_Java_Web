{% extends 'front/layout.html.twig' %}

{% block title %}{{ article is defined ? 'Modifier l\'article' : 'Nouvel article' }} — FARMTECH{% endblock %}

{% block front_content %}
<div class="farmer-dashboard" style="max-width: 800px; margin: 0 auto;">

    <article class="farmer-home-card">
        <div class="farmer-home-card__intro">
            <a href="{{ path('app_blog_show', {'idBlog': blog.idBlog}) }}" class="btn btn-ghost mb-3" style="padding-left: 0;">&larr; Retour au blog</a>
            <header class="farmer-home-card__head">
                <h1 class="farmer-home-card__title">
                    {% if article is defined %}Modifier l'article{% else %}Nouvel article{% endif %}
                </h1>
            </header>
        </div>
    </article>

    <article class="farmer-home-card mt-4">
        <div class="farmer-home-card__intro">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                <div class="mb-3">
                    {{ form_label(form.title, 'Titre', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                    {{ form_widget(form.title, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.title) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.text, 'Contenu', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                    {{ form_widget(form.text, {'attr': {'class': 'form-control', 'rows': 10}}) }}
                    {{ form_errors(form.text) }}
                </div>

                <div class="d-flex justify-content-end mt-4">
                    <button type="submit" class="btn btn-primary">Enregistrer</button>
                </div>

            {{ form_end(form) }}
        </div>
    </article>

</div>
{% endblock %}